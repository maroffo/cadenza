# ABOUTME: Local dev environment template; copy to .env (gitignored) and fill.
# ABOUTME: Prod equivalents live in Cloud Run env vars + Secret Manager (pinned versions).

ENV=dev
PORT=8080

# intervals.icu (cadenza config)
ICU_API_KEY=
ICU_ATHLETE_ID=0
# ICU_RATE_PER_SEC=3

# The copied internal/icu integration tests use their own names:
# INTERVALS_API_KEY=, INTERVALS_ATHLETE_ID=  (go test -tags=integration)

# Firestore: dev talks to the emulator (note: not :8080, the service uses that)
GCP_PROJECT=cadenza-dev
FIRESTORE_EMULATOR_HOST=localhost:8090

ATHLETE_TZ=Europe/Rome
