# ABOUTME: Local dev environment template; copy to .env (gitignored) and fill.
# ABOUTME: Prod equivalents live in Cloud Run env vars + Secret Manager (pinned versions).

ENV=dev
PORT=8080

# intervals.icu (cadenza config)
ICU_API_KEY=
ICU_ATHLETE_ID=0
# ICU_RATE_PER_SEC=3

# The copied internal/icu integration tests use their own names:
# INTERVALS_API_KEY=, INTERVALS_ATHLETE_ID=  (go test -tags=integration)

# Telegram (dev bot from BotFather; chat id from @userinfobot until M3 /start)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Executor OIDC + queue (prod only; unused by --job/--poll dev runs)
# EXECUTOR_AUDIENCE=https://cadenza-....run.app
# INVOKER_EMAIL=cadenza-invoker@<project>.iam.gserviceaccount.com
# TELEGRAM_WEBHOOK_SECRET=<random, also passed to deploy/set-webhook.sh>
# TASKS_QUEUE_PATH=projects/<project>/locations/europe-west1/queues/cadenza-exec

# Firestore: dev talks to the emulator (note: not :8080, the service uses that)
GCP_PROJECT=cadenza-dev
FIRESTORE_EMULATOR_HOST=localhost:8090

# Anthropic (M4+): key for the coach voice; base URL only for tests
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=
# MODEL_CHEAP=claude-haiku-4-5-20251001

ATHLETE_TZ=Europe/Rome
